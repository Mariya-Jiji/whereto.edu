# =========================================
# College Discovery Platform — Environment Variables
# =========================================
# Copy this file to .env.local and fill in values

# ---- Database (Neon PostgreSQL) ----
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---- NextAuth.js ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-string"
# For local dev:
NEXTAUTH_URL="http://localhost:3000"
# For production (Vercel auto-sets this from domain, but set explicitly to be safe):
# NEXTAUTH_URL="https://your-app.vercel.app"
